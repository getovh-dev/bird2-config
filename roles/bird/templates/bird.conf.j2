log syslog all;
debug protocols all;

router id {{ router_id }};

protocol kernel {
    scan time 60;
    ipv6 {
        export filter {
            # Export routes from BGP, node_v6, router_v6 and master_v6 (also master_6); reject other static routes
            if source = RTS_STATIC && proto != "master_v6" && proto != "master_6" && proto != "node_v6" && proto != "router_v6" then reject;
            {% if krt_prefsrc_v6 is defined and krt_prefsrc_v6|trim %}
            if source = RTS_BGP then krt_prefsrc = {{ krt_prefsrc_v6 }};
            {% endif %}
            accept;
        };
    };
} 

protocol device {
    scan time 60;
}

include "filter_bgp.conf";

{% macro static_attrs(p) -%}
    {% if p is mapping and (p.prepend is defined or p.origin is defined) %}
    {
        {% if p.prepend is defined %}
            {% if p.prepend is iterable and p.prepend is not string %}
                {% for asn in p.prepend %}
        bgp_path.prepend({{ asn }});
                {% endfor %}
            {% else %}
                {% for i in range(p.prepend|int) %}
        bgp_path.prepend({{ local_as }});
                {% endfor %}
            {% endif %}
        {% endif %}
    }
    {% endif %}
{%- endmacro %}

protocol static node_v6 {
    ipv6;
{% for p in blackhole_v6|default([]) %}
    {% if p.via is defined %}
    route {{ p.prefix }} via "{{ p.via }}" {{ static_attrs(p) }};
    {% else %}
    route {{ p.prefix if p.prefix is defined else p }} blackhole {{ static_attrs(p) }};
    {% endif %}
{% endfor %}
} 

protocol static router_v6 {
    ipv6;
{% for p in blackhole_prefix_v6|default([]) %}
    {% if p.via is defined %}
    route {{ p.prefix }} via "{{ p.via }}" {{ static_attrs(p) }};
    {% else %}
    route {{ p.prefix if p.prefix is defined else p }} blackhole {{ static_attrs(p) }};
    {% endif %}
{% endfor %}
}

protocol static master_v6 {
{% if static_routes_master6|default([])|length == 0 %}
    ipv6 { table master6; };
{% else %}
    ipv6 { table master6; };
{% for r in static_routes_master6|default([]) %}
    {% if r.via is string and (':' in r.via or '.' in r.via) %}
    route {{ r.prefix|default(r.network) }} via {{ r.via }};
    {% else %}
    route {{ r.prefix|default(r.network) }} via "{{ r.via }}";
    {% endif %}
{% endfor %}
{% endif %}
}

{% macro pname(n,t,p) -%}
{{ (n ~ '_' ~ t ~ '_' ~ p)|lower|regex_replace('[^a-z0-9_]', '_') }}
{%- endmacro %}

{% macro local_line(s) -%}
{% if s.local_asn is defined %}
    {% if s.local_address is defined %}local {{ s.local_address }} as {{ s.local_asn }};{% else %}local as {{ s.local_asn }};{% endif %}
{% else %}
    {% if s.local_address is defined %}local {{ s.local_address }} as {{ local_as }};{% else %}local as {{ local_as }};{% endif %}
{% endif %}
{%- endmacro %}

{% macro add_export_comms(s) -%}
{% if s.add_on_export is defined or (s['add-on-export'] is defined) %}
    {% if s.add_on_export is defined %}
        {% set raw = s.add_on_export %}
    {% else %}
        {% set raw = s['add-on-export'] %}
    {% endif %}
    {% if raw is string %}
        {% set comms = raw.split(',') %}
    {% else %}
        {% set comms = raw %}
    {% endif %}
    {% for c in comms %}
        {% set _c = c | string | trim | replace('(', '') | replace(')', '') %}
        {% if ':' in _c %}
            {% set parts = _c.split(':') %}
            bgp_community.add(({{ parts[0]|trim }}, {{ parts[1]|trim }}));
        {% elif ',' in _c %}
            {% set parts = _c.split(',') %}
            bgp_community.add(({{ parts[0]|trim }}, {{ parts[1]|trim }}));
        {% else %}
            bgp_community.add({{ _c }});
        {% endif %}
    {% endfor %}
{% endif %}
{%- endmacro %}

{% macro export_with_add(s, cond_expr, remote_as) -%}
{% if (s.add_on_export is defined and (s.add_on_export is string and s.add_on_export|trim or s.add_on_export is iterable)) or (s['add-on-export'] is defined and (s['add-on-export'] is string and s['add-on-export']|trim or s['add-on-export'] is iterable)) %}
export filter {
    {% if s.force_export is defined and s.force_export|length > 0 %}
        {% set _force = s.force_export %}
        if ( {% for p in _force %} net = {{ p }}{% if not loop.last %} || {% endif %}{% endfor %} ) then accept;
    {% endif %}
    {{ add_export_comms(s) }}
    {{ reject_no_export(s) }}
    {% if s.prepend is defined and s.prepend|int > 0 %}
        {% set _pp = s.prepend|int if s.prepend|int <= 3 else 3 %}
        bgp_large_community.add((MY_ASN, LC_PREPEND_{{ _pp }}, {{ remote_as }}));
        if ({{ cond_expr }}) then {
            handle_prepend({{ remote_as }});
            accept;
        }
        reject;
    {% else %}
        if ({{ cond_expr }}) then accept;
        reject;
    {% endif %}
};
next hop self;
{% else %}
    {% if s.force_export is defined and s.force_export|length > 0 %}
    export filter {
        {% set _force = s.force_export %}
        if ( {% for p in _force %} net = {{ p }}{% if not loop.last %} || {% endif %}{% endfor %} ) then accept;
        {{ reject_no_export(s) }}
        if ({{ cond_expr }}) then accept;
        reject;
    };
    next hop self;
    {% else %}
{{ export_where_respect_no_export(s, cond_expr) }}
    {% endif %}
{% endif %}
{%- endmacro %}

{% macro reject_no_export(s) -%}
{% if (s.no_export is defined and (s.no_export is string and s.no_export|trim or s.no_export is iterable)) or (s['no-export'] is defined and (s['no-export'] is string and s['no-export']|trim or s['no-export'] is iterable)) %}
    {% if s.no_export is defined %}
        {% set _raw = s.no_export %}
    {% else %}
        {% set _raw = s['no-export'] %}
    {% endif %}
    {% if _raw is string %}
        {% set _nets = _raw.split(',') %}
    {% else %}
        {% set _nets = _raw %}
    {% endif %}
    if ( {% for p in _nets %} net = {{ p }}{% if not loop.last %} || {% endif %}{% endfor %} ) then reject;
{%- endif %}
{%- endmacro %}

{% macro export_where_respect_no_export(s, cond_expr) -%}
{% if (s.no_export is defined and (s.no_export is string and s.no_export|trim or s.no_export is iterable)) or (s['no-export'] is defined and (s['no-export'] is string and s['no-export']|trim or s['no-export'] is iterable)) %}
export filter {
    {% if s.force_export is defined and s.force_export|length > 0 %}
        {% set _force = s.force_export %}
        if ( {% for p in _force %} net = {{ p }}{% if not loop.last %} || {% endif %}{% endfor %} ) then accept;
    {% endif %}
    {{ add_export_comms(s) }}
    {{ reject_no_export(s) }}
    if ({{ cond_expr }}) then accept;
    reject;
};
next hop self;
{% else %}
export where {{ cond_expr }};
next hop self;
{% endif %}
{%- endmacro %}

